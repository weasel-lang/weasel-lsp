#include "weasel/factory.hpp"
#include "weasel/node.hpp"
#include "weasel/renderer.hpp"
#include <iostream>
#include <optional>
#include <string>
#include <vector>

using namespace weasel;

struct task {
    std::string title;
    std::string assignee;
};

struct badge_props {
    std::string label;
    std::optional<std::string> color;
};

struct task_item_props {
    const task&          item;
    std::optional<bool>  show_assignee;
};

struct task_list_props {
    const std::vector<task>& items;
    std::optional<std::string> title;
};

component badge(const badge_props& p) {
    std::string cls = "badge";
    if (p.color) {
        cls += " badge-" + *p.color;
    }
    return <span class={cls}>{p.label}</span>;
}

component task_item(const task_item_props& p) {
    const bool show = p.show_assignee.value_or(true);
    return (
        <li class="task-item">
            <h3 class="task-title">{p.item.title}</h3>
            {
                if (show && !p.item.assignee.empty()) {
                    <p class="assignee">
                        Assigned To <badge label={p.item.assignee} color="blue" />
                    </p>
                }
            }
        </li>
    );
}

component task_list(const task_list_props& p) {
    return (
        <div class="page">
            {
                if (p.title) {
                    <h2>{*p.title}</h2>
                }
            }
            <ul class="task-list">
                {
                    for (const auto& t : p.items) {
                        <task_item item={t} />
                    }
                }
            </ul>
        </div>
    );
}

int main() {
    const std::vector<task> tasks = {
        {"Fix login bug",       "Alice"},
        {"Write release notes", "Bob"},
        {"Deploy to staging",   ""},
    };

    node page = task_list({.items = tasks, .title = "Sprint Tasks"});

    std::cout << "<!DOCTYPE html>\n"
              << "<html><body>\n";
    render(page, std::cout);
    std::cout << "\n</body></html>\n";
    return 0;
}
